{
  "name": "@modernrelay/omnigraph",
  "version": "0.3.0",
  "description": "TypeScript SDK for the Omnigraph HTTP API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ModernRelay/omnigraph-ts.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/ModernRelay/omnigraph-ts",
  "bugs": "https://github.com/ModernRelay/omnigraph/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist src/generated",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.64.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
